{
  "buildCommand": "pnpm --filter @workspace/mobile run web:build",
  "outputDirectory": "artifacts/mobile/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}